<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.sevenchannel.infrastructure.mapper.BoardMapper">
	<select id="findAll" resultType="com.example.sevenchannel.domain.model.boards.BoardEntity">
		select
			id
			,name
			,description
			,created_at as createdAt
		from boards
	</select>
</mapper>