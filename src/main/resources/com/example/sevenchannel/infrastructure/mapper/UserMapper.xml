<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.sevenchannel.infrastructure.mapper.UserMapper">
	<select id="findById" parameterType="string" resultType="com.example.sevenchannel.domain.model.users.UserEntity">
		SELECT id,username,pwd_hash,created_at FROM users
		WHERE "id" = #{id}
	</select>
	<insert id="save" parameterType="com.example.sevenchannel.domain.model.users.UserEntity">
		INSERT INTO users(id,username,pwd_hash,created_at)
		VALUES(#{id},#{username},#{pwdHash},#{createdAt})
	</insert>
</mapper>